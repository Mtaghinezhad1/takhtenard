import Leftbar from "@/components/index/Leftbar";
import Rightbar from "@/components/index/rightbar";
import { Text, View, StyleSheet, TouchableOpacity } from "react-native";
import React, { useState } from "react";
import { InitialBoard } from "@/constants/constants";


import HalfBoard from "@/components/index/halfBoard";
import StaticsBar from "@/components/index/staticsBat";
import GameStatusBar from "@/components/index/leftStatusBar";

export default function Index() {
  const [gameState, setGameState] = useState({
    board: InitialBoard,
    currentPlayer: 'white', // 1 سفید، -1 سیاه
    dice: [], // تاس‌های ریخته شده
    availableMoves: [], // حرکات ممکن
    turnPhase: 'rolling' // 'rolling', 'moving', 'done'
  });
  const [board, setBoard] = useState(InitialBoard);
  const [currentTurn, setCurrentTurn] = useState("white");
  const [movesCount, setMovesCount] = useState(0);

  // تابع اعتبارسنجی حرکت
const isValidMove = (board, fromPoint, diceNumber, currentTurn) => {
  // 1. بررسی معتبر بودن نقطه مبدا
  if (fromPoint < 1 || fromPoint > 24) return false;
  
  const sourceValue = board[fromPoint - 1];
  
  // 2. بررسی وجود مهره در مبدا
  if (sourceValue === 0) return false;
  
  // 3. بررسی تعلق مهره به بازیکن فعلی
  if ((sourceValue > 0 && currentTurn !== 'white') || 
      (sourceValue < 0 && currentTurn !== 'black')) {
    return false;
  }
  
  // 4. محاسبه نقطه مقصد بر اساس جهت حرکت
  let targetPoint;
  if (currentTurn == 'white') { // سفید: حرکت به سمت چپ (کاهش شماره)
    targetPoint = fromPoint - diceNumber;
  } else { // سیاه: حرکت به سمت راست (افزایش شماره)
    targetPoint = fromPoint + diceNumber;
  }
  
  // 5. بررسی خارج از تخته نبودن
  if (targetPoint < 1 || targetPoint > 24) {
    // TODO: منطق بیرون انداختن مهره (bear off) را بعداً اضافه کنید
    return false;
  }
  
  const targetValue = board[targetPoint - 1];
  
  // 6. بررسی اشغال بودن نقطه مقصد توسط حریف
  // اگر در نقطه مقصد مهره حریف باشد و تعداد آن بیشتر از 1 باشد، حرکت مجاز نیست
  if (targetValue * currentTurn < -1) {
    return false; // نقطه توسط بیش از یک مهره حریف اشغال شده
  }
  
  // TODO: قوانین دیگر مانند تاس‌های تکراری، حرکت با هر دو تاس و ...
  
  return true;
};

  // تابع اجرای حرکت
  const makeMove = (board, fromPoint, diceNumber, currentTurn, prevBoard) => {
    const newBoard = [...board];

    // محاسبه نقطه مقصد
    let targetPoint;
    if (currentTurn == "white") {
      targetPoint = fromPoint - diceNumber;
    } else {
      targetPoint = fromPoint + diceNumber;
    }

    const sourceValue = newBoard[fromPoint - 1];
    const targetValue = newBoard[targetPoint - 1];

    // Check if it's the correct turn based on piece color
    if ((sourceValue > 0 && currentTurn !== "white") || (sourceValue < 0 && currentTurn !== "black")) {
      return prevBoard;
    }

    // کاهش مهره از مبدا
    if (sourceValue > 0) {
      newBoard[fromPoint - 1] = sourceValue - 1;
    } else {
      newBoard[fromPoint - 1] = sourceValue + 1;
    }

    // افزایش مهره به مقصد (با در نظر گرفتن خوردن مهره حریف)
    if (sourceValue > 0) {
      // اگر در مقصد مهره حریف تنها باشد (blot)
      if (targetValue === -1) {
        // مهره حریف خورده می‌شود و به bar می‌رود
        // TODO: منطق ارسال به bar را اضافه کنید
        newBoard[targetPoint - 1] = 1;
      } else {
        newBoard[targetPoint - 1] = targetValue + 1;
      }
    } else {
      if (targetValue === 1) {
        newBoard[targetPoint - 1] = -1;
      } else {
        newBoard[targetPoint - 1] = targetValue - 1;
      }
    }

    return newBoard;
  };

  const handlePointPress = (pointId, diceNumber = 2) => {
    if(isValidMove(board,pointId,diceNumber,currentTurn)){
      setBoard(prevBoard => {
        const newBoard = makeMove(prevBoard, pointId, diceNumber, currentTurn, prevBoard);
  
        // Increment moves count and check if turn should switch
        const newMovesCount = movesCount + 1;
        setMovesCount(newMovesCount);
  
        if (newMovesCount >= 2) {
          setCurrentTurn(currentTurn === "white" ? "black" : "white");
          setMovesCount(0);
        }
  
        return newBoard;
      });
    }
    
  };

  return (
    <View style={{flex:1}}>
      <View style={styles.board}>
        <GameStatusBar currentTurn={currentTurn}/>
        <Leftbar />
        <HalfBoard side="left" board={board} onPointPress={handlePointPress} />
        <StaticsBar />
        <HalfBoard side="right" board={board} onPointPress={handlePointPress} />
        <Rightbar />
      </View>
    </View>

  );
}

const styles = StyleSheet.create({
  board: {
    aspectRatio: 16/9,
    flexDirection: 'row',
    justifyContent: 'space-between',
    backgroundColor: '#070024',
  },
});
