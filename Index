import Leftbar from "@/components/index/Leftbar";
import Rightbar from "@/components/index/rightbar";
import { Text, View, StyleSheet, TouchableOpacity } from "react-native";
import React, { useState, useEffect } from "react";
import { InitialBoard } from "@/constants/constants";


import HalfBoard from "@/components/index/halfBoard";
import StaticsBar from "@/components/index/staticsBat";
import GameStatusBar from "@/components/index/leftStatusBar";

export default function Index() {
  const [gameState, setGameState] = useState({
    board: InitialBoard,
    currentPlayer: 'white', // 1 سفید، -1 سیاه
    dice: [], // تاس‌های ریخته شده
    availableMoves: [], // حرکات ممکن
    turnPhase: 'rolling' // 'rolling', 'moving', 'done'
  });
  const [board, setBoard] = useState(InitialBoard);
  const [currentTurn, setCurrentTurn] = useState("white");
  const [movesCount, setMovesCount] = useState(0);
  const [dice, setDice] = useState([1, 1]); // مقداردهی اولیه تاس‌ها

  // تابع ریختن تاس
  const rollDice = () => {
    const dice1 = Math.floor(Math.random() * 6) + 1;
    const dice2 = Math.floor(Math.random() * 6) + 1;

    setDice([dice1, dice2]);
  };

  // تابع اعتبارسنجی حرکت
  const isValidMove = (board, fromPoint, diceNumber, currentTurn) => {
    // بررسی وجود مهره در بار برای بازیکن فعلی
    const whiteBarCount = board[25]; // مهره‌های سفید در بار
    const blackBarCount = board[0];  // مهره‌های سیاه در بار

    // اگر مهره‌ای در بار وجود دارد، باید ابتدا آن‌ها را وارد بازی کرد
    if (currentTurn === 'white' && whiteBarCount > 0) {
      // اگر مهره سفید در بار است، فقط می‌تواند از بار وارد بازی شود
      if (fromPoint !== 25) {
        return false; // باید ابتدا مهره را از بار وارد کند
      }

      // محاسبه نقطه ورود برای مهره سفید (از بار به تخته)
      // مهره سفید از بار (25) به نقطه 25-diceNumber می‌رود
      const entryPoint = 25 - diceNumber;
      if (entryPoint < 1 || entryPoint > 24) return false;

      const targetValue = board[entryPoint];
      // بررسی اشغال بودن نقطه ورود توسط حریف
      if (targetValue < -1) return false; // نقطه توسط بیش از یک مهره حریف اشغال شده

      return true;
    }

    if (currentTurn === 'black' && blackBarCount < 0) {
      // اگر مهره سیاه در بار است، فقط می‌تواند از بار وارد بازی شود
      if (fromPoint !== 0) {
        return false; // باید ابتدا مهره را از بار وارد کند
      }

      // محاسبه نقطه ورود برای مهره سیاه (از بار به تخته)
      // مهره سیاه از بار (0) به نقطه diceNumber می‌رود
      const entryPoint = diceNumber;
      if (entryPoint < 1 || entryPoint > 24) return false;

      const targetValue = board[entryPoint];
      // بررسی اشغال بودن نقطه ورود توسط حریف
      if (targetValue > 1) return false; // نقطه توسط بیش از یک مهره حریف اشغال شده

      return true;
    }




    // 1. بررسی معتبر بودن نقطه مبدا
    if (fromPoint < 1 || fromPoint > 24) return false;

    const sourceValue = board[fromPoint];

    // 2. بررسی وجود مهره در مبدا
    if (sourceValue === 0) return false;

    // 3. بررسی تعلق مهره به بازیکن فعلی
    if ((sourceValue > 0 && currentTurn !== 'white') ||
      (sourceValue < 0 && currentTurn !== 'black')) {
      return false;
    }

    // 4. محاسبه نقطه مقصد بر اساس جهت حرکت
    let targetPoint;
    if (currentTurn == 'white') { // سفید: حرکت به سمت چپ (کاهش شماره)
      targetPoint = fromPoint - diceNumber;
    } else { // سیاه: حرکت به سمت راست (افزایش شماره)
      targetPoint = fromPoint + diceNumber;
    }

    // 5. بررسی خارج از تخته نبودن
    if (targetPoint < 1 || targetPoint > 24) {
      // TODO: منطق بیرون انداختن مهره (bear off) را بعداً اضافه کنید
      return false;
    }

    const targetValue = board[targetPoint];

    // 6. بررسی اشغال بودن نقطه مقصد توسط حریف
    // اگر در نقطه مقصد مهره حریف باشد و تعداد آن بیشتر از 1 باشد، حرکت مجاز نیست
    if ((targetValue < -1 && currentTurn == 'white') || (targetValue > 1 && currentTurn == 'black')) {
      return false; // نقطه توسط بیش از یک مهره حریف اشغال شده
    }

    // TODO: قوانین دیگر مانند تاس‌های تکراری، حرکت با هر دو تاس و ...

    return true;
  };

  // تابع اجرای حرکت
  const makeMove = (board, fromPoint, diceNumber, currentTurn, prevBoard) => {
    const newBoard = [...board];

    // محاسبه نقطه مقصد
    let targetPoint;
    if (currentTurn == "white") {
      targetPoint = fromPoint - diceNumber;
    } else {
      targetPoint = fromPoint + diceNumber;
    }

    const sourceValue = newBoard[fromPoint];
    const targetValue = newBoard[targetPoint];

    // Check if it's the correct turn based on piece color
    if ((sourceValue > 0 && currentTurn !== "white") || (sourceValue < 0 && currentTurn !== "black")) {
      return prevBoard;
    }

    // کاهش مهره از مبدا
    if (sourceValue > 0) {
      newBoard[fromPoint] = sourceValue - 1;
    } else {
      newBoard[fromPoint] = sourceValue + 1;
    }

    // مدیریت نقطه مقصد
    if (sourceValue > 0) { // حرکت مهره سفید
      if (targetValue === -1) {
        // خوردن مهره سیاه تنها (blot)
        newBoard[targetPoint] = 1; // مهره سفید در مقصد قرار می‌گیرد
        // مهره سیاه خورده شده به بار سیاه (index 0) می‌رود
        newBoard[0] = newBoard[0] - 1; // افزایش مهره سیاه در بار
      } else if (targetValue < 0) {
        // مقصد پر از مهره سیاه است - این حالت نباید رخ دهد چون isValidMove باید جلوگیری کند
        return prevBoard;
      } else {
        // مقصد خالی یا دارای مهره سفید
        newBoard[targetPoint] = targetValue + 1;
      }
    } else { // حرکت مهره سیاه
      if (targetValue === 1) {
        // خوردن مهره سفید تنها (blot)
        newBoard[targetPoint] = -1; // مهره سیاه در مقصد قرار می‌گیرد
        // مهره سفید خورده شده به بار سفید (index 25) می‌رود
        newBoard[25] = newBoard[25] + 1; // افزایش مهره سفید در بار
      } else if (targetValue > 0) {
        // مقصد پر از مهره سفید است - این حالت نباید رخ دهد
        return prevBoard;
      } else {
        // مقصد خالی یا دارای مهره سیاه
        newBoard[targetPoint] = targetValue - 1;
      }
    }

    return newBoard;
  };

  const handlePointPress = (pointId) => {
    const diceNumber = dice[0];
    if (isValidMove(board, pointId, diceNumber, currentTurn)) {
      setBoard(prevBoard => {
        const newBoard = makeMove(prevBoard, pointId, diceNumber, currentTurn, prevBoard);

        setDice(dice.slice(1));

        // Increment moves count and check if turn should switch
        const newMovesCount = movesCount + 1;
        setMovesCount(newMovesCount);

        if (newMovesCount >= 2) {
          setCurrentTurn(currentTurn === "white" ? "black" : "white");
          setMovesCount(0);
          rollDice();
        }

        return newBoard;
      });
    }
  };

  // ریختن تاس در شروع بازی
  useEffect(() => {
    rollDice();
  }, []);

  return (
    <View style={{ flex: 1 }}>
      <View style={styles.board}>
        <GameStatusBar currentTurn={currentTurn} />
        <Leftbar />
        <HalfBoard side="left" dice={dice} board={board} onPointPress={handlePointPress} />
        <StaticsBar blackCaptured={board[0]} whiteCaptured={board[25]} />
        <HalfBoard side="right" dice={dice} board={board} onPointPress={handlePointPress} />
        <Rightbar />
      </View>
    </View>

  );
}

const styles = StyleSheet.create({
  board: {
    aspectRatio: 16 / 9,
    flexDirection: 'row',
    justifyContent: 'space-between',
    backgroundColor: '#070024',
  },
});
